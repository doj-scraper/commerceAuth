## 5. Advanced: Quantity Selection Modal

**Optional Enhancement**: Let users choose quantity (not just default to 5).

```typescript
// Create a modal/dialog for quantity selection
const handleAddToCart = useCallback(
  (part: PartMaster) => {
    if (part.stock === 0) {
      toast.error(`${part.sku} is out of stock`);
      return;
    }

    // Show modal to select quantity
    const quantity = prompt(
      `How many units of ${part.sku}? (Minimum: 5)`,
      '5'
    );

    if (!quantity) return; // User cancelled

    const qty = parseInt(quantity, 10);

    if (isNaN(qty) || qty < 5) {
      toast.error('Quantity must be at least 5');
      return;
    }

    if (qty > part.stock) {
      toast.error(`Only ${part.stock} units available`);
      return;
    }

    const addItem = useCartStore((state) => state.addItem);
    addItem({
      partId: part.id,
      sku: part.sku,
      quantity: qty,
      price: part.price,
      addedAt: new Date(),
    });

    toast.success(
      `Added ${part.sku} (${qty} units) to cart`
    );
  },
  []
);
```

